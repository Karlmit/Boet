<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Boet" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/warm_white</item>
        <item name="android:navigationBarColor">@color/warm_white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/warm_white</item>
    </style>

    <!-- Splash background while Compose loads -->
    <style name="Theme.Boet.Splash" parent="Theme.Boet">
        <item name="android:windowBackground">@color/warm_white</item>
    </style>
</resources>
